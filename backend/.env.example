NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/croo_hub

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client
CLIENT_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# CROO Network (CAP) integration - see CROO_CAP_COMPATIBILITY_REPORT.md
# Obtain CROO_SDK_KEY by registering an Agent at https://agent.croo.network (My Agents -> Register Agent).
# The key is shown once at registration time - store it securely, this app never re-displays it.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_SDK_KEY=
CROO_RPC_URL=https://mainnet.base.org
