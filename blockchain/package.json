{
  "name": "croo-hub-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "CROO Hub on-chain trust layer: agent identity, escrow commerce, reputation, and workflow orchestration proofs for the AI Agent Economy.",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:localhost": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:baseSepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "verify:baseSepolia": "hardhat run scripts/verify.ts --network baseSepolia",
    "lint": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write '**/*.{ts,sol,json}'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/node": "^20.14.9",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.10",
    "prettier": "^3.3.2",
    "prettier-plugin-solidity": "^1.4.1",
    "solhint": "^5.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  }
}
