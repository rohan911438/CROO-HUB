# ---------------------------------------------------------------------------
# CROO Hub contracts - environment configuration
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# Deployer private key (no 0x prefix or with, both accepted). Use a dedicated
# throwaway/testnet key for Base Sepolia - never reuse a mainnet key here.
PRIVATE_KEY=

# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Basescan API key, used by hardhat-verify to verify source code on Base Sepolia.
# Get one at https://basescan.org/myapikey
BASESCAN_API_KEY=

# USDC token address to wire the Escrow contract to.
# Base Sepolia official USDC (Circle testnet faucet token) as of writing:
#   0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Leave empty to auto-deploy MockUSDC instead (recommended for local/testnet demos).
USDC_ADDRESS=

# Address that receives protocol fees taken by EscrowCommerce (defaults to deployer if empty).
FEE_RECIPIENT=

# Protocol fee in basis points (100 = 1%). 0 disables fees entirely. Max enforced on-chain is 1000 (10%).
PROTOCOL_FEE_BPS=0

# Admin address to receive DEFAULT_ADMIN_ROLE / VERIFIER_ROLE / ARBITRATOR_ROLE on deploy.
# Defaults to the deployer address if left empty. Use a multisig in production.
ADMIN_ADDRESS=

# Enable gas reporting during tests (true/false)
REPORT_GAS=false

# Optional: CoinMarketCap API key for USD gas cost estimates in gas-reporter
COINMARKETCAP_API_KEY=
